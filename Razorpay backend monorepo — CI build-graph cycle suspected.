import java.util.*;

public class TopoCycleDetection {

    static final int WHITE = 0;
    static final int GREY = 1;
    static final int BLACK = 2;

    static class TopoResult {
        List<String> order;
        List<String> cycle;

        TopoResult(List<String> order, List<String> cycle) {
            this.order = order;
            this.cycle = cycle;
        }
    }

    public static TopoResult topoSortWithCycle(Map<String, List<String>> adj) {

        Map<String, Integer> color = new HashMap<>();
        Map<String, String> parent = new HashMap<>();

        List<String> order = new ArrayList<>();
        List<String> cycle = new ArrayList<>();

        // initialize all nodes as WHITE
        for (String node : adj.keySet()) {
            color.put(node, WHITE);
        }

        // run DFS for all nodes
        for (String node : adj.keySet()) {
            if (color.get(node) == WHITE) {
                if (dfs(node, adj, color, parent, order, cycle)) {
                    return new TopoResult(null, cycle);
                }
            }
        }

        Collections.reverse(order);
        return new TopoResult(order, Collections.emptyList());
    }

    private static boolean dfs(String u,
                               Map<String, List<String>> adj,
                               Map<String, Integer> color,
                               Map<String, String> parent,
                               List<String> order,
                               List<String> cycle) {

        color.put(u, GREY);

        for (String v : adj.getOrDefault(u, new ArrayList<>())) {

            if (color.getOrDefault(v, WHITE) == WHITE) {
                parent.put(v, u);

                if (dfs(v, adj, color, parent, order, cycle)) {
                    return true;
                }

            } else if (color.get(v) == GREY) {

                // ✅ Cycle detected - reconstruct path
                cycle.add(v);

                String cur = u;
                while (cur != null && !cur.equals(v)) {
                    cycle.add(cur);
                    cur = parent.get(cur);
                }

                cycle.add(v);
                Collections.reverse(cycle);

                return true;
            }
        }

        color.put(u, BLACK);
        order.add(u);

        return false;
    }

    // 🔹 Test Driver
    public static void main(String[] args) {

        Map<String, List<String>> graph = new HashMap<>();

        graph.put("A", Arrays.asList("B"));
        graph.put("B", Arrays.asList("C"));
        graph.put("C", Arrays.asList("D"));
        graph.put("D", Arrays.asList("B")); // cycle here

        TopoResult result = topoSortWithCycle(graph);

        if (result.order == null) {
            System.out.println("Cycle Detected:");
            System.out.println(result.cycle);
        } else {
            System.out.println("Topological Order:");
            System.out.println(result.order);
        }
    }
}
