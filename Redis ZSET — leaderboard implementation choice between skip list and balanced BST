import java.util.Random;

public class SkipListDemo {

    static class SkipNode {
        int score;
        String member;
        SkipNode[] forward;

        SkipNode(int score, String member, int level) {
            this.score = score;
            this.member = member;
            this.forward = new SkipNode[level + 1];
        }
    }

    static final int MAX_LEVEL = 16;
    static final double P = 0.5;

    private int currentLevel = 0;
    private final SkipNode head = new SkipNode(Integer.MIN_VALUE, "", MAX_LEVEL);
    private final Random rng = new Random();

    private int randomLevel() {
        int lvl = 0;
        while (rng.nextDouble() < P && lvl < MAX_LEVEL) {
            lvl++;
        }
        return lvl;
    }

    public SkipNode search(int score) {
        SkipNode cur = head;

        for (int i = currentLevel; i >= 0; i--) {
            while (cur.forward[i] != null &&
                   cur.forward[i].score < score) {
                cur = cur.forward[i];
            }
        }

        cur = cur.forward[0];

        if (cur != null && cur.score == score) {
            return cur;
        }

        return null;
    }

    public void insert(int score, String member) {

        SkipNode[] update = new SkipNode[MAX_LEVEL + 1];
        SkipNode cur = head;

        for (int i = currentLevel; i >= 0; i--) {
            while (cur.forward[i] != null &&
                   cur.forward[i].score < score) {
                cur = cur.forward[i];
            }
            update[i] = cur;
        }

        int lvl = randomLevel();

        if (lvl > currentLevel) {
            for (int i = currentLevel + 1; i <= lvl; i++) {
                update[i] = head;
            }
            currentLevel = lvl;
        }

        SkipNode node = new SkipNode(score, member, lvl);

        for (int i = 0; i <= lvl; i++) {
            node.forward[i] = update[i].forward[i];
            update[i].forward[i] = node;
        }
    }

    public void display() {
        System.out.println("\nLeaderboard:");
        SkipNode cur = head.forward[0];

        while (cur != null) {
            System.out.println(cur.member + " - Score: " + cur.score);
            cur = cur.forward[0];
        }
    }

    public static void main(String[] args) {

        SkipListDemo leaderboard = new SkipListDemo();

        leaderboard.insert(150, "Alice");
        leaderboard.insert(300, "Bob");
        leaderboard.insert(200, "Charlie");
        leaderboard.insert(400, "David");

        leaderboard.display();

        SkipNode result = leaderboard.search(300);

        if (result != null) {
            System.out.println("\nFound: " +
                    result.member +
                    " with score " +
                    result.score);
        } else {
            System.out.println("\nScore not found.");
        }
    }
}
